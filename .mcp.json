{
  "mcpServers": {
    "ast-grep": {
      "command": "uv",
      "args": ["run", "--project", "${CLAUDE_PLUGIN_ROOT}/servers", "python", "${CLAUDE_PLUGIN_ROOT}/servers/ast-grep-server.py"],
      "env": {}
    },
    "omca-state": {
      "command": "uv",
      "args": ["run", "--project", "${CLAUDE_PLUGIN_ROOT}/servers", "python", "${CLAUDE_PLUGIN_ROOT}/servers/omca-state-server.py"],
      "env": {}
    },
    "grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
