{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/gc-in-use-markers.sh"
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-init.sh"
					}
				]
			},
			{
				"matcher": "compact",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-compact-inject.sh"
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/keyword-detector.sh"
					}
				]
			}
		],
		"UserPromptExpansion": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/slash-command-mode-detector.sh"
					}
				]
			}
		],
		"SubagentStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/subagent-start.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Grep",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/executor-grep-deny.sh"
					}
				]
			},
			{
				"matcher": "Write",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/write-guard.sh"
					}
				]
			},
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "mcp_tool",
						"server": "plugin:oh-my-claudeagent:omca",
						"tool": "validate_plan_write",
						"input": {
							"tool_name": "${tool_name}",
							"file_path": "${tool_input.file_path}",
							"content": "${tool_input.content}",
							"new_string": "${tool_input.new_string}",
							"old_string": "${tool_input.old_string}"
						}
					}
				]
			}
		],
		"PermissionRequest": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"if": "Bash(rm *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(npm *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(jq *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(uv *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(sudo *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(bun *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(yarn *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(pnpm *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(git *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/git-destructive-deny.sh"
					},
					{
						"type": "command",
						"if": "Bash(sed *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/sed-grep-deny.sh"
					},
					{
						"type": "command",
						"if": "Bash(grep *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/sed-grep-deny.sh"
					},
					{
						"type": "command",
						"if": "Bash(grep *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/executor-grep-deny.sh"
					}
				]
			},
			{
				"matcher": "ExitPlanMode",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/plan-mode-handler.sh"
					}
				]
			}
		],
		"PermissionDenied": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-denied-coach.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-edit.sh",
						"async": true
					}
				]
			},
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/comment-checker.sh"
					}
				]
			},
			{
				"matcher": "Read|Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/context-injector.sh"
					}
				]
			},
			{
				"matcher": "Agent",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/empty-task-response.sh"
					}
				]
			}
		],
		"PostToolUseFailure": [
			{
				"matcher": "Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/edit-error-recovery.sh"
					}
				]
			},
			{
				"matcher": "Agent",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/delegate-retry.sh"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/bash-error-recovery.sh"
					}
				]
			},
			{
				"matcher": "Read",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/read-error-recovery.sh"
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/json-error-recovery.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/final-verification-evidence.sh"
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/drift-guard.sh"
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact.sh"
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-cleanup.sh",
						"timeout": 5000
					}
				]
			}
		],
		"TaskCompleted": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/task-completed-verify.sh"
					}
				]
			}
		]
	}
}
