{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/gc-in-use-markers.sh"
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-init.sh"
					}
				]
			},
			{
				"matcher": "compact",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-compact-inject.sh"
					}
				]
			}
		],
		"InstructionsLoaded": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/instructions-loaded-audit.sh",
						"async": true
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/keyword-detector.sh"
					}
				]
			}
		],
		"SubagentStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/subagent-start.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Agent",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/track-subagent-spawn.sh"
					}
				]
			},
			{
				"matcher": "Write",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/write-guard.sh"
					}
				]
			},
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "mcp_tool",
						"server": "omca",
						"tool": "validate_plan_write",
						"input": {
							"tool_name": "${tool_name}",
							"file_path": "${tool_input.file_path}",
							"content": "${tool_input.content}",
							"new_string": "${tool_input.new_string}",
							"old_string": "${tool_input.old_string}"
						}
					}
				]
			}
		],
		"PermissionRequest": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"if": "Bash(rm *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(npm *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(jq *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(uv *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(sudo *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(bun *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(yarn *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					},
					{
						"type": "command",
						"if": "Bash(pnpm *)",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-filter.sh"
					}
				]
			},
			{
				"matcher": "ExitPlanMode",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/plan-mode-handler.sh"
					}
				]
			}
		],
		"PermissionDenied": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/permission-denied-coach.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "AskUserQuestion",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/track-question.sh"
					}
				]
			},
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-edit.sh",
						"async": true
					}
				]
			},
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/comment-checker.sh"
					}
				]
			},
			{
				"matcher": "Read|Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/context-injector.sh"
					}
				]
			},
			{
				"matcher": "Grep|Glob|WebFetch|WebSearch",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/agent-usage-reminder.sh"
					}
				]
			},
			{
				"matcher": "Agent",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/empty-task-response.sh"
					}
				]
			}
		],
		"PostToolUseFailure": [
			{
				"matcher": "Edit",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/edit-error-recovery.sh"
					}
				]
			},
			{
				"matcher": "Agent",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/delegate-retry.sh"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/bash-error-recovery.sh"
					}
				]
			},
			{
				"matcher": "Read",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/read-error-recovery.sh"
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/json-error-recovery.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/ralph-persistence.sh"
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/final-verification-evidence.sh"
					}
				]
			}
		],
		"StopFailure": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/stop-failure-handler.sh"
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/subagent-complete.sh"
					}
				]
			}
		],
		"TaskCreated": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/lifecycle-state.sh"
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact.sh"
					}
				]
			}
		],
		"PostCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-compact-log.sh"
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-cleanup.sh",
						"timeout": 5000
					}
				]
			}
		],
		"Notification": [
			{
				"matcher": "idle_prompt|permission_prompt",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/notify.sh",
						"async": true
					}
				]
			}
		],
		"TaskCompleted": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/task-completed-verify.sh"
					}
				]
			}
		],
		"TeammateIdle": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/teammate-idle-guard.sh"
					}
				]
			}
		],
		"ConfigChange": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/config-change-audit.sh",
						"async": true
					}
				]
			}
		],
		"CwdChanged": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/lifecycle-state.sh"
					}
				]
			}
		],
		"FileChanged": [
			{
				"matcher": ".mcp.json|AGENTS.md|CLAUDE.md|hooks.json|plugin.json|settings.json|pyproject.toml|justfile",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/lifecycle-state.sh"
					}
				]
			}
		],
		"WorktreeCreate": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/lifecycle-state.sh"
					}
				]
			}
		],
		"WorktreeRemove": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/lifecycle-state.sh"
					}
				]
			}
		]
	}
}
