#!/usr/bin/env bash
# omca-status — Print OMCA state summary.
# Read-only: never mutates state. Exit 0 on success, 1 on missing state dir.
# No `set -euo pipefail` — degrade gracefully on missing state files.

PROJECT_ROOT="${HOOK_PROJECT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
STATE_DIR="${PROJECT_ROOT}/.omca/state"

if [ ! -d "$STATE_DIR" ]; then
    echo "omca-status: no .omca/state/ in this project; run /oh-my-claudeagent:omca-setup first." >&2
    exit 1
fi

echo "=== Boulder (active plan) ==="
if [ -f "$STATE_DIR/boulder.json" ]; then
    jq -r '
      "  plan_name: \(.plan_name // "unknown")",
      "  active_plan: \(.active_plan // "unknown")",
      "  started_at: \(.started_at // "unknown")",
      "  sessions: \(.session_ids | length)",
      "  agent: \(.agent // "sisyphus")"
    ' "$STATE_DIR/boulder.json"
else
    echo "  (no active plan)"
fi
echo

echo "=== Verification evidence ==="
if [ -f "$STATE_DIR/verification-evidence.json" ]; then
    TOTAL=$(jq -r '.entries | length' "$STATE_DIR/verification-evidence.json" 2>/dev/null || echo 0)
    echo "  total entries: $TOTAL"
    if [ "$TOTAL" -gt 0 ]; then
        jq -r '.entries | group_by(.type)[] | "    \(.[0].type): \(length)"' "$STATE_DIR/verification-evidence.json"
    fi
else
    echo "  (none)"
fi
echo

echo "=== Pending final-verify (F1-F4) ==="
if [ -f "$STATE_DIR/pending-final-verify.json" ]; then
    jq -r '
      "  plan: \(.plan_path | split("/") | .[-1])",
      "  plan_sha256: \(.plan_sha256[:16])…",
      "  marked_at: \(.marked_at)",
      "  session_id: \(.session_id // "unknown")"
    ' "$STATE_DIR/pending-final-verify.json"
else
    echo "  (no pending wave)"
fi
echo

echo "=== Subagents ==="
if [ -f "$STATE_DIR/subagents.json" ]; then
    jq -r '
      "  active (in subagents.json): \(.active | length)",
      "  completed this session: \(.completed | length)"
    ' "$STATE_DIR/subagents.json"
fi
if [ -f "$STATE_DIR/active-agents.json" ]; then
    AC=$(jq -r 'length' "$STATE_DIR/active-agents.json" 2>/dev/null || echo 0)
    echo "  active (in active-agents.json): $AC"
fi
echo

echo "=== Active modes ==="
if [ -f "$STATE_DIR/active-modes.json" ]; then
    jq -r 'to_entries[] | "  \(.key): \(.value.detected_at // "?")"' "$STATE_DIR/active-modes.json"
else
    echo "  (none)"
fi

exit 0
