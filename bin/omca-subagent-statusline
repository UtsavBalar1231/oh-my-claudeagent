#!/usr/bin/env python3
"""Subagent statusline renderer for OMCA — emits one JSON line per task row override."""
from __future__ import annotations

import json
import sys

# Python version guard — the int|None union syntax requires py310+; fail soft so a stale
# system python doesn't crash the statusline.
if sys.version_info < (3, 10):
    sys.exit(0)


def fmt_tokens(n: int | None) -> str:
    if n is None or n <= 0:
        return ""
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}k"
    return str(n)


def main() -> int:
    data = json.load(sys.stdin)
    cols = int(data.get("columns") or 80)
    for task in data.get("tasks") or []:
        task_id = task.get("id")
        if not task_id:
            continue
        name = task.get("name") or "task"
        kind = task.get("type") or ""
        status = task.get("status") or ""
        label = task.get("label") or ""
        tokens = fmt_tokens(task.get("tokenCount"))
        # Compose: name [type] · status · label · tokens
        bits = [name]
        if kind:
            bits.append(f"[{kind}]")
        if status:
            bits.append(f"· {status}")
        if label and label not in bits:
            bits.append(f"· {label}")
        if tokens:
            bits.append(f"· {tokens}t")
        content = " ".join(bits)
        # Truncate to columns
        if len(content) > cols:
            content = content[: cols - 1] + "…"
        sys.stdout.write(json.dumps({"id": task_id, "content": content}) + "\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
